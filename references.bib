	keywords = {EURO-CORDEX, Climate change, CORDEX, Regional climate models, Regional climate modelling},
	pages = {51},
	file = {Full Text PDF:C\:\\Users\\wdwettin\\Zotero\\storage\\A3U9NRKC\\Jacob et al. - 2020 - Regional climate downscaling over Europe perspect.pdf:application/pdf},
